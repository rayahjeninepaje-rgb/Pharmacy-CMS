-- ============================================================
-- TABLE: customer
-- ============================================================

-- SELECT: USER sees ACTIVE only; ADMIN/SUPERADMIN see all
CREATE POLICY cust_visibility ON customer
FOR SELECT TO authenticated
USING (
  record_status = 'ACTIVE'
  OR EXISTS (
    SELECT 1 FROM public.user
    WHERE userid = auth.uid()::text
    AND user_type IN ('ADMIN', 'SUPERADMIN')
  )
);

-- INSERT: only users with CUST_ADD = 1
CREATE POLICY cust_insert ON customer
FOR INSERT TO authenticated
WITH CHECK (
  EXISTS (
    SELECT 1 FROM public.user_module_rights
    WHERE userid = auth.uid()::text
    AND rightid = 'CUST_ADD'
    AND right_value = 1
  )
);

-- UPDATE (edit): only users with CUST_EDIT = 1
CREATE POLICY cust_update ON customer
FOR UPDATE TO authenticated
USING (
  EXISTS (
    SELECT 1 FROM public.user_module_rights
    WHERE userid = auth.uid()::text
    AND rightid = 'CUST_EDIT'
    AND right_value = 1
  )
);

-- UPDATE record_status to INACTIVE (soft delete): only CUST_DEL = 1
CREATE POLICY cust_soft_delete ON customer
FOR UPDATE TO authenticated
USING (
  EXISTS (
    SELECT 1 FROM public.user_module_rights
    WHERE userid = auth.uid()::text
    AND rightid = 'CUST_DEL'
    AND right_value = 1
  )
);

