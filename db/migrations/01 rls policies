-- ============================================================
-- TABLE: user
-- ============================================================

-- SELECT: each user can read their own row
CREATE POLICY admin_and_self_view ON "user"
FOR SELECT TO authenticated
USING (
  userid = auth.uid()::text
);

-- UPDATE: ADMIN can update record_status only for non-SUPERADMIN users
CREATE POLICY admin_manage_users ON "user"
FOR UPDATE TO authenticated
USING (
  userid = auth.uid()::text
  OR (
    EXISTS (
      SELECT 1 FROM public.user
      WHERE userid = auth.uid()::text
      AND user_type IN ('ADMIN', 'SUPERADMIN')
    )
    AND user_type != 'SUPERADMIN'
  )
);